# Disable codesigning in local development.
# This prevents electron-builder from checking keychain for a signing cert.
CSC_IDENTITY_AUTO_DISCOVERY=false

# Use a local editable install of omni-code instead of the bundled venv version.
# Only takes effect in development mode (NODE_ENV=development).
# OMNI_CODE_DEV_PATH=/home/emm/.local/bin/omni
