# Template for infra/deploy.env (which is GITIGNORED — copy this, fill in, and
# never commit the filled copy). deploy.sh sources infra/deploy.env if present,
# so a redeploy reuses the existing deployment's secrets/identifiers instead of
# generating new ones (a fresh random PG password or a new AAD app would break
# the live environment).
#
# For a brand-NEW environment you can skip most of this — deploy.sh generates
# secrets and creates the AAD app on first run. Capture the generated values
# back into infra/deploy.env afterwards so future redeploys are non-destructive.

# --- identifiers (not secret) ---
export RG=omni-launcher-rg
export LOCATION=southcentralus
# The EXACT site name of the running app (has a unique suffix). Get it with:
#   az webapp list --query "[].name" -o tsv
export SITE_NAME=omni-launcher-xxxxxxxxxxxx
export ACR_NAME=omnilauncheracr
export AUTH_MODE=easyauth
export AZURE_SUBSCRIPTION_ID=$(az account show --query id -o tsv)
# AAD app (client) id for EasyAuth:
#   az webapp auth show -g $RG -n $SITE_NAME \
#     --query "identityProviders.azureActiveDirectory.registration.clientId" -o tsv
export AAD_CLIENT_ID=

# --- secrets (reuse the LIVE values to avoid clobbering the deployment) ---
# Postgres admin password — DECODED (deploy.sh/bicep URL-encode it). Extract
# from the running app's connection string and URL-decode:
#   az webapp config appsettings list -g $RG -n $SITE_NAME \
#     --query "[?name=='OMNI_DATABASE_URL'].value" -o tsv
#   # then urldecode the user:PASSWORD@ portion (%2B->+ %2F->/ etc.)
export PG_PASSWORD=
# Password for the non-superuser omni_app role the launcher connects as (RLS-enforced).
# az webapp config appsettings list ... --query "[?name=='OMNI_DATABASE_URL'].value" -o tsv  # then urldecode the omni_app:PASSWORD@ portion
export OMNI_APP_PASSWORD=
# az webapp config appsettings list ... --query "[?name=='OMNI_RUNTIME_TOKEN_SECRET'].value" -o tsv
export RUNTIME_TOKEN_SECRET=
# ... name=='OMNI_WS_TOKEN'
export WS_TOKEN=
# AES-256-GCM key (32 bytes, base64) used by PgSecretStore for column-level
# encryption of git/codex/team secrets. ROTATING IT ORPHANS EVERY EXISTING
# user_secrets / team_secrets ROW — pin to the live value.
# az keyvault secret show --vault-name <kv> --name omni-secret-key --query value -o tsv
# (or: az webapp config appsettings list ... --query "[?name=='OMNI_SECRET_KEY']" — it's a KV ref)
export OMNI_SECRET_KEY=
# ... name=='MICROSOFT_PROVIDER_AUTHENTICATION_SECRET'  (the AAD client secret)
export AAD_CLIENT_SECRET=

# Public (tokenless) package index used to bake omni-code into the image.
export OMNI_PIP_INDEX='https://pypi.fury.io/ericmichael/'
